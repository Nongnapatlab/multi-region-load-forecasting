<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nongnapat.loadforecasting</string>

    <!-- Runs: /bin/bash <project>/run_daily_mac.sh -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/run_daily_mac.sh</string>
    </array>

    <!-- Run every day at 06:00 local time. Adjust Hour/Minute as needed. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Do not run immediately when the plist is loaded — only at the
         scheduled time above. Set to true if you want an immediate run
         the first time you load it (e.g. for testing). -->
    <key>RunAtLoad</key>
    <false/>

    <!-- Working directory for the job (so relative paths inside the
         script behave the same as running it manually from a terminal). -->
    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <!-- launchd-level stdout/stderr (separate from the pipeline's own
         output/logs/daily_run.log, which is written by run_daily_mac.sh
         itself). Useful for diagnosing launchd-specific failures, e.g. the
         script not being found or not being executable. -->
    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/output/logs/launchd_out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/output/logs/launchd_err.log</string>
</dict>
</plist>
